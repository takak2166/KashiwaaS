{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/after-file-edit-lint.sh",
        "timeout": 120
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/stop-run-tests.sh",
        "timeout": 600,
        "failClosed": true
      }
    ]
  }
}
