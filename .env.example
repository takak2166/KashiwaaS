SLACK_API_TOKEN=xoxb-your-token-here
SLACK_CHANNEL_ID=C12345678
SLACK_CHANNEL_NAME=your-channel
SLACK_ALERT_CHANNEL_ID=C87654321

# KashiwaaS Bot (Socket Mode)
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Valkey (Slack thread -> Cursor agent mapping; redis:// URL)
VALKEY_URL=redis://valkey:6379/0

# Mattermost KashiwaaS bot (optional; set URL + PAT together or omit all Mattermost vars). Thread keys use prefix mm: in Valkey.
# MATTERMOST_URL=https://chat.example.com
# MATTERMOST_PAT=your-personal-access-token
# Optional: must match the user id of the PAT (GET /api/v4/users/me); omit to resolve automatically after login.
# MATTERMOST_BOT_USER_ID=
# MATTERMOST_VERIFY_TLS=true
#   false disables TLS certificate verification (MITM risk). Dev/self-signed only—not for production.
# MATTERMOST_LOG_RAW_WEBSOCKET=false
#   true logs raw WebSocket frames at INFO (may include post bodies). Short-lived debugging only.
# Optional: TTL in seconds (default 30 days). Refreshed on each read/write (sliding).
# VALKEY_THREAD_TTL_SECONDS=2592000

# Cursor Cloud Agents API
CURSOR_API_KEY=key_your-cursor-api-key
CURSOR_SOURCE_REPOSITORY=https://github.com/takak2166/KashiwaaS
CURSOR_SOURCE_REF=main
CURSOR_POLL_INTERVAL=5
CURSOR_POLL_TIMEOUT=600
# Model: explicit ID (e.g. composer-2), or Auto / default / empty to use API default. See GET https://api.cursor.com/v0/models for available IDs.
CURSOR_MODEL=composer-2
# After FINISHED: retry conversation GET until the latest assistant message id advances (eventual consistency).
CURSOR_CONVERSATION_RETRY_MAX_RETRIES=4
CURSOR_CONVERSATION_RETRY_DELAY_SECONDS=1.5
# Then poll until assistant text is unchanged for N consecutive reads (interval seconds apart, max extra rounds). Reduces partial replies right after FINISHED.
CURSOR_CONVERSATION_TEXT_STABILIZE_INTERVAL_SECONDS=1.0
CURSOR_CONVERSATION_TEXT_STABILIZE_REQUIRED_MATCHES=3
CURSOR_CONVERSATION_TEXT_STABILIZE_MAX_ROUNDS=60

ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme

KIBANA_HOST=http://kibana:5601
KIBANA_USERNAME=elastic
KIBANA_PASSWORD=changeme

SELENIIUM_HOST=http://chrome:4444

# Plotly weekly charts (Kaleido): path to Chromium/Chrome on the host. Docker image sets BROWSER_PATH=/usr/bin/chromium.
# BROWSER_PATH=/usr/bin/chromium

LOG_LEVEL=INFO
LOG_RETENTION=7 days

TIMEZONE=Asia/Tokyo

# Alert settings
ALERT_MIN_LEVEL=WARNING  # INFO, WARNING, ERROR, CRITICAL
ALERT_THROTTLE_SECONDS=300
ALERT_MAX_PER_HOUR=10