SLACK_API_TOKEN=xoxb-your-token-here
SLACK_CHANNEL_ID=C12345678
SLACK_CHANNEL_NAME=your-channel
SLACK_ALERT_CHANNEL_ID=C87654321

# KashiwaaS Bot (Socket Mode)
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Cursor Cloud Agents API
CURSOR_API_KEY=key_your-cursor-api-key
CURSOR_SOURCE_REPOSITORY=https://github.com/takak2166/KashiwaaS
CURSOR_SOURCE_REF=main
CURSOR_POLL_INTERVAL=5
CURSOR_POLL_TIMEOUT=300
# Model: explicit ID (e.g. composer-2), or Auto / default / empty to use API default. See GET https://api.cursor.com/v0/models for available IDs.
CURSOR_MODEL=composer-2

ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme

KIBANA_HOST=http://kibana:5601
KIBANA_USERNAME=elastic
KIBANA_PASSWORD=changeme

SELENIIUM_HOST=http://chrome:4444

LOG_LEVEL=INFO
LOG_RETENTION=7 days

TIMEZONE=Asia/Tokyo

# Alert settings
ALERT_MIN_LEVEL=WARNING  # INFO, WARNING, ERROR, CRITICAL
ALERT_THROTTLE_SECONDS=300
ALERT_MAX_PER_HOUR=10